# ── LLM Provider Configuration ──
# Set ONE of the provider API keys below, or use LLM_PROVIDER + LLM_API_KEY + LLM_BASE_URL
# for any OpenAI-compatible provider.

# Option 1: Anthropic (default if ANTHROPIC_API_KEY is set)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Option 2: OpenAI
# OPENAI_API_KEY=sk-your-key-here

# Option 3: Google Gemini
# GEMINI_API_KEY=your-key-here

# Option 4: Any OpenAI-compatible provider (Groq, OpenRouter, Together, Ollama, vLLM, xAI, Mistral, Cerebras, etc.)
# LLM_PROVIDER=groq
# LLM_API_KEY=your-key-here
# LLM_BASE_URL=https://api.groq.com/openai/v1

# ── Optional ──
# LLM_MODEL=claude-sonnet-4-20250514       # Override model for planning + execution
# EXECUTION_MODEL=claude-sonnet-4-20250514  # Override model for execution only
# OPENCLAW_REPO=/path/to/openclaw-main  # Path to OpenClaw checkout (optional)
